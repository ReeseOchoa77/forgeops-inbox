generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum PlatformRole {
  PLATFORM_ADMIN
  STANDARD_USER
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum MailboxStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
  ERROR
}

enum IngestionMode {
  NATIVE
  N8N
}

enum InboxProvider {
  GMAIL
  OUTLOOK
}

enum ApprovedAccessStatus {
  ACTIVE
  REVOKED
}

enum InboxConnectionStatus {
  ACTIVE
  PAUSED
  ERROR
  REQUIRES_REAUTH
  DISCONNECTED
}

enum IngestionSource {
  NATIVE
  N8N
}

enum BusinessCategory {
  BUSINESS
  NON_BUSINESS
}

enum MailboxCategory {
  BUSINESS
  PERSONAL
  SPAM
  TRASH
}

enum EmailType {
  ACTIONABLE_REQUEST
  FYI_UPDATE
  SALES_MARKETING
  SUPPORT_CUSTOMER_ISSUE
  RECRUITING_HIRING
  INTERNAL_COORDINATION
  NEEDS_REVIEW
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ItemStatus {
  NEW
  NEEDS_REVIEW
  ROUTED
  IN_PROGRESS
  RESOLVED
  CLOSED
  ARCHIVED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ReviewQueue {
  TRIAGE
  EXTRACTION
  ROUTING
  QA
}

enum ReviewStatus {
  NOT_REQUIRED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum RoutingRuleActionType {
  ASSIGN
  SET_PRIORITY
  SET_STATUS
  CREATE_TASK
  SEND_TO_REVIEW_QUEUE
}

/// Workspace is the tenant boundary. Every operational record below is scoped
/// to a workspace to keep inbox data isolated in a multi-tenant deployment.
enum JobStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Workspace {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  timezone         String            @default("UTC")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      Membership[]
  inboxConnections InboxConnection[]
  emailThreads     EmailThread[]
  emailMessages    EmailMessage[]
  normalizedEmails NormalizedEmail[]
  classifications  Classification[]
  tasks            Task[]
  routingRules     RoutingRule[]
  setting          WorkspaceSetting?
  auditEvents      AuditEvent[]
  approvedAccess   ApprovedAccess[]
  customers        Customer[]
  vendors          Vendor[]
  jobs             Job[]
  entityAliases    EntityAlias[]
  entityContacts   EntityContact[]
  knowledgeDocs    KnowledgeDocument[]
  importRuns       ImportRun[]
  workspaceMailboxes WorkspaceMailbox[]
  businessTypes      BusinessType[]
  classificationCorrections ClassificationCorrection[]
  classificationInstructions ClassificationInstruction[]
  discoveredFolders    DiscoveredFolder[]
  jobFolderRoots       JobFolderRoot[]
  senderEvidence       SenderEvidence[]
  domainEvidence       DomainEvidence[]
  emailAttachments     EmailAttachment[]
}

model User {
  id                      String           @id @default(cuid())
  googleSubject           String?          @unique
  email                   String           @unique
  name                    String?
  avatarUrl               String?
  lastLoginAt             DateTime?
  isPlatformAdmin         Boolean          @default(false)
  platformRole            PlatformRole     @default(STANDARD_USER)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  memberships             Membership[]
  assignedThreads         EmailThread[]    @relation("ThreadAssignee")
  assignedTasks           Task[]           @relation("TaskAssignee")
  reviewedClassifications Classification[] @relation("ClassificationReviewer")
  reviewedTasks           Task[]           @relation("TaskReviewer")
  createdRoutingRules     RoutingRule[]    @relation("RoutingRuleCreator")
  updatedRoutingRules     RoutingRule[]    @relation("RoutingRuleUpdater")
  auditEvents             AuditEvent[]     @relation("AuditActor")
  invitedAccess           ApprovedAccess[] @relation("ApprovedAccessInviter")
  createdDocuments        KnowledgeDocument[] @relation("DocumentCreator")
  classificationCorrections ClassificationCorrection[] @relation("CorrectionReviewer")
  classificationInstructions ClassificationInstruction[] @relation("InstructionCreator")
}

model ApprovedAccess {
  id              String               @id @default(cuid())
  email           String
  workspaceId     String
  role            Role                 @default(MEMBER)
  workspaceRole   WorkspaceRole        @default(VIEWER)
  status          ApprovedAccessStatus @default(ACTIVE)
  invitedByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedByUser   User?                @relation("ApprovedAccessInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, email])
  @@index([email])
  @@index([workspaceId, status])
}

model Membership {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role            Role          @default(MEMBER)
  workspaceRole   WorkspaceRole @default(VIEWER)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
  @@index([workspaceId, workspaceRole])
}

model InboxConnection {
  id                String                @id @default(cuid())
  workspaceId       String
  provider          InboxProvider         @default(GMAIL)
  email             String
  displayName       String?
  providerAccountId String?
  status            InboxConnectionStatus @default(ACTIVE)
  ingestionSource   IngestionSource       @default(NATIVE)
  grantedScopes     String[]              @default([])
  encryptedAccessToken String?
  encryptedRefreshToken String?
  accessTokenExpiresAt DateTime?
  connectedAt       DateTime?
  disconnectedAt    DateTime?
  syncCursor        String?
  lastSyncStartedAt DateTime?
  lastSyncedAt      DateTime?
  lastSyncErrorAt   DateTime?
  lastSyncError     String?
  pushSubscriptionId String?
  pushExpiresAt     DateTime?
  lastReceivedAt    DateTime?
  lastProcessedAt   DateTime?
  lastErrorMessage  String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  threads           EmailThread[]
  messages          EmailMessage[]
  normalizedEmails  NormalizedEmail[]
  workspaceMailboxes WorkspaceMailbox[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, provider, email])
  @@index([providerAccountId])
  @@index([workspaceId, email])
  @@index([workspaceId, providerAccountId])
  @@index([workspaceId, provider])
  @@index([workspaceId, status])
  @@index([provider, email, ingestionSource])
}

model EmailThread {
  id                         String        @id @default(cuid())
  workspaceId                String
  inboxConnectionId          String
  unifiedThreadKey           String?
  gmailThreadId              String
  providerThreadId           String?
  subject                    String?
  normalizedSubject          String?
  snippet                    String?
  participants               Json?
  firstMessageAt             DateTime?
  lastMessageAt              DateTime?
  messageCount               Int           @default(0)
  unreadCount                Int           @default(0)
  priority                   Priority?
  itemStatus                 ItemStatus    @default(NEW)
  assignedToUserId           String?
  reviewQueue                ReviewQueue?
  reviewStatus               ReviewStatus  @default(NOT_REQUIRED)
  latestClassificationConfidence Decimal?  @db.Decimal(5, 4)
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  workspace                  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inboxConnection            InboxConnection @relation(fields: [workspaceId, inboxConnectionId], references: [workspaceId, id], onDelete: Cascade)
  assignedToUser             User?         @relation("ThreadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages                   EmailMessage[]
  normalizedEmails           NormalizedEmail[]
  classifications            Classification[]
  tasks                      Task[]        @relation("TaskSourceThread")

  @@unique([workspaceId, id])
  @@unique([inboxConnectionId, gmailThreadId])
  @@index([gmailThreadId])
  @@index([workspaceId, gmailThreadId])
  @@index([providerThreadId])
  @@index([workspaceId, providerThreadId])
  @@index([workspaceId, unifiedThreadKey])
  @@index([workspaceId, lastMessageAt])
  @@index([workspaceId, itemStatus, lastMessageAt])
  @@index([workspaceId, assignedToUserId, itemStatus])
  @@index([workspaceId, reviewQueue, reviewStatus])
}

model EmailMessage {
  id               String        @id @default(cuid())
  workspaceId      String
  inboxConnectionId String
  threadId         String
  gmailMessageId   String
  gmailThreadId    String
  providerMessageId String?
  providerThreadId  String?
  historyId        String?
  subject          String?
  senderName       String?
  senderEmail      String
  toAddresses      Json?
  ccAddresses      Json?
  bccAddresses     Json?
  replyToAddresses Json?
  snippet          String?
  bodyText         String?
  bodyHtml         String?
  labelIds         String[]      @default([])
  hasAttachments   Boolean       @default(false)
  isRead           Boolean       @default(false)
  isImportant      Boolean       @default(false)
  isTrashed        Boolean       @default(false)
  isSpam           Boolean       @default(false)
  mailboxCategory  MailboxCategory @default(BUSINESS)
  trashedAt        DateTime?
  trashedBy        String?
  previousCategory MailboxCategory?
  attachmentMetadata Json?
  sentAt           DateTime
  receivedAt       DateTime?
  priority         Priority?
  itemStatus       ItemStatus    @default(NEW)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inboxConnection  InboxConnection @relation(fields: [workspaceId, inboxConnectionId], references: [workspaceId, id], onDelete: Cascade)
  thread           EmailThread   @relation(fields: [workspaceId, threadId], references: [workspaceId, id], onDelete: Cascade)
  normalizedEmail  NormalizedEmail?
  classifications  Classification[]
  tasks            Task[]        @relation("TaskSourceMessage")
  attachments      EmailAttachment[]

  @@unique([workspaceId, id])
  @@unique([inboxConnectionId, gmailMessageId])
  @@index([gmailMessageId])
  @@index([gmailThreadId])
  @@index([workspaceId, gmailMessageId])
  @@index([workspaceId, gmailThreadId])
  @@index([providerMessageId])
  @@index([providerThreadId])
  @@index([workspaceId, providerMessageId])
  @@index([workspaceId, providerThreadId])
  @@index([workspaceId, inboxConnectionId, receivedAt])
  @@index([workspaceId, historyId])
  @@index([workspaceId, sentAt])
  @@index([workspaceId, mailboxCategory, receivedAt])
  @@index([workspaceId, threadId, sentAt])
  @@index([workspaceId, itemStatus, sentAt])
  @@index([senderEmail])
}

model NormalizedEmail {
  id               String          @id @default(cuid())
  workspaceId      String
  inboxConnectionId String
  threadId         String
  messageId        String
  sender           Json
  recipients       Json
  subject          String?
  normalizedSubject String?
  snippet          String?
  receivedAt       DateTime?
  cleanTextBody    String?
  labelHints       String[]        @default([])
  categoryHints    String[]        @default([])
  senderDomain     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inboxConnection  InboxConnection @relation(fields: [workspaceId, inboxConnectionId], references: [workspaceId, id], onDelete: Cascade)
  thread           EmailThread     @relation(fields: [workspaceId, threadId], references: [workspaceId, id], onDelete: Cascade)
  message          EmailMessage    @relation(fields: [workspaceId, messageId], references: [workspaceId, id], onDelete: Cascade)

  @@unique([workspaceId, id])
  @@unique([workspaceId, messageId])
  @@index([workspaceId, inboxConnectionId, receivedAt])
  @@index([workspaceId, senderDomain])
}

model Classification {
  id                    String       @id @default(cuid())
  workspaceId           String
  threadId              String
  messageId             String?
  businessCategory      BusinessCategory?
  emailType             EmailType
  priority              Priority?
  itemStatus            ItemStatus?
  summary               String?
  companyName           String?
  projectName           String?
  deadline              DateTime?
  containsActionRequest Boolean      @default(false)
  routingHints          Json?
  extractedFields       Json?
  confidence            Decimal      @db.Decimal(5, 4)
  requiresReview        Boolean      @default(false)
  reviewQueue           ReviewQueue?
  reviewStatus          ReviewStatus @default(NOT_REQUIRED)
  reviewedByUserId      String?
  reviewedAt            DateTime?
  modelName             String?
  modelVersion          String?
  customerId            String?
  vendorId              String?
  jobId                 String?
  mailboxCategory       MailboxCategory?
  mailboxConfidence     Decimal?     @db.Decimal(5, 4)
  businessTypeKey       String?
  businessTypeConfidence Decimal?    @db.Decimal(5, 4)
  entityMatchConfidence Decimal?     @db.Decimal(5, 4)
  matchEvidence         Json?
  rawAiPayload          Json?
  classificationEvidence Json?
  candidateIds          Json?
  classifierVersion     String?
  promptVersion         String?
  processedAt           DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  workspace             Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  thread                EmailThread  @relation(fields: [workspaceId, threadId], references: [workspaceId, id], onDelete: Cascade)
  message               EmailMessage? @relation(fields: [workspaceId, messageId], references: [workspaceId, id], onDelete: SetNull)
  reviewedByUser        User?        @relation("ClassificationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  customer              Customer?    @relation("ClassificationCustomer", fields: [workspaceId, customerId], references: [workspaceId, id], onDelete: SetNull)
  vendor                Vendor?      @relation("ClassificationVendor", fields: [workspaceId, vendorId], references: [workspaceId, id], onDelete: SetNull)
  job                   Job?         @relation("ClassificationJob", fields: [workspaceId, jobId], references: [workspaceId, id], onDelete: SetNull)
  tasks                 Task[]
  corrections           ClassificationCorrection[]

  @@unique([workspaceId, id])
  @@index([workspaceId, businessCategory])
  @@index([workspaceId, emailType])
  @@index([workspaceId, priority])
  @@index([workspaceId, itemStatus])
  @@index([workspaceId, confidence])
  @@index([workspaceId, reviewQueue, reviewStatus])
  @@index([workspaceId, requiresReview, confidence])
  @@unique([workspaceId, messageId])
  @@index([threadId, createdAt])
  @@index([messageId])
  @@index([customerId])
  @@index([vendorId])
  @@index([jobId])
}

model Task {
  id               String       @id @default(cuid())
  workspaceId      String
  sourceThreadId   String
  sourceMessageId  String?
  classificationId String?
  assigneeUserId   String?
  assigneeGuess    String?
  sourceTaskKey    String?
  title            String
  summary          String?
  description      String?
  dueAt            DateTime?
  priority         Priority     @default(MEDIUM)
  status           TaskStatus   @default(OPEN)
  confidence       Decimal      @db.Decimal(5, 4)
  requiresReview   Boolean      @default(false)
  reviewQueue      ReviewQueue?
  reviewStatus     ReviewStatus @default(NOT_REQUIRED)
  reviewedByUserId String?
  reviewedAt       DateTime?
  completedAt      DateTime?
  dismissedAt      DateTime?
  dismissedBy      String?
  dismissalReason  String?
  customerId       String?
  vendorId         String?
  jobId            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceThread     EmailThread  @relation("TaskSourceThread", fields: [workspaceId, sourceThreadId], references: [workspaceId, id], onDelete: Cascade)
  sourceMessage    EmailMessage? @relation("TaskSourceMessage", fields: [workspaceId, sourceMessageId], references: [workspaceId, id], onDelete: SetNull)
  classification   Classification? @relation(fields: [workspaceId, classificationId], references: [workspaceId, id], onDelete: SetNull)
  assigneeUser     User?        @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  reviewedByUser   User?        @relation("TaskReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  customer         Customer?    @relation("TaskCustomer", fields: [workspaceId, customerId], references: [workspaceId, id], onDelete: SetNull)
  vendor           Vendor?      @relation("TaskVendor", fields: [workspaceId, vendorId], references: [workspaceId, id], onDelete: SetNull)
  job              Job?         @relation("TaskJob", fields: [workspaceId, jobId], references: [workspaceId, id], onDelete: SetNull)

  @@unique([workspaceId, id])
  @@index([workspaceId, status, dueAt])
  @@index([workspaceId, assigneeUserId, status])
  @@index([workspaceId, priority, status])
  @@index([workspaceId, confidence])
  @@index([workspaceId, reviewQueue, reviewStatus])
  @@unique([workspaceId, sourceMessageId, sourceTaskKey])
  @@index([sourceThreadId])
  @@index([sourceMessageId])
  @@index([classificationId])
  @@index([customerId])
  @@index([vendorId])
  @@index([jobId])
}

/// Domain entity: a customer/client the workspace does business with.
/// Designed for spreadsheet import. Matching to emails is deferred.
model Customer {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  normalizedName  String
  primaryEmail    String?
  domain          String?
  phone           String?
  externalRef     String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  jobs            Job[]     @relation("JobCustomer")
  classifications Classification[] @relation("ClassificationCustomer")
  tasks           Task[]    @relation("TaskCustomer")
  aliases         EntityAlias[]
  contacts        EntityContact[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, domain])
  @@index([workspaceId, primaryEmail])
  @@index([workspaceId, externalRef])
}

/// Domain entity: a vendor/supplier the workspace works with.
model Vendor {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  normalizedName  String
  primaryEmail    String?
  domain          String?
  phone           String?
  externalRef     String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  classifications Classification[] @relation("ClassificationVendor")
  tasks           Task[]    @relation("TaskVendor")
  aliases         EntityAlias[]
  contacts        EntityContact[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, domain])
  @@index([workspaceId, primaryEmail])
  @@index([workspaceId, externalRef])
}

/// Domain entity: a job/project tied to a customer.
model Job {
  id              String     @id @default(cuid())
  workspaceId     String
  jobNumber       String?
  name            String
  normalizedName  String
  customerId      String?
  status          JobStatus  @default(ACTIVE)
  externalRef     String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer        Customer?  @relation("JobCustomer", fields: [workspaceId, customerId], references: [workspaceId, id], onDelete: SetNull)
  classifications Classification[] @relation("ClassificationJob")
  tasks           Task[]     @relation("TaskJob")
  aliases           EntityAlias[]
  discoveredFolders DiscoveredFolder[]

  @@unique([workspaceId, id])
  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, jobNumber])
  @@index([workspaceId, customerId])
  @@index([workspaceId, status])
  @@index([workspaceId, externalRef])
}

model WorkspaceMailbox {
  id                          String        @id @default(cuid())
  workspaceId                 String
  emailAddress                String
  normalizedEmail             String
  provider                    InboxProvider @default(OUTLOOK)
  displayName                 String?
  status                      MailboxStatus @default(ACTIVE)
  ingestionMode               IngestionMode @default(N8N)
  inboxConnectionId           String?
  lastMessageSeenAt           DateTime?
  lastSuccessfulProcessingAt  DateTime?
  lastErrorAt                 DateTime?
  lastErrorMessage            String?
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  workspace                   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inboxConnection             InboxConnection? @relation(fields: [inboxConnectionId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, normalizedEmail])
  @@unique([normalizedEmail, provider])
  @@index([workspaceId, status])
  @@index([normalizedEmail])
  @@index([provider, normalizedEmail])
}

model RoutingRule {
  id              String                @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  enabled         Boolean               @default(true)
  priorityOrder   Int                   @default(100)
  stopProcessing  Boolean               @default(false)
  actionType      RoutingRuleActionType
  matchCriteria   Json
  actionConfig    Json
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser   User?                 @relation("RoutingRuleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?                 @relation("RoutingRuleUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, id])
  @@unique([workspaceId, name])
  @@index([workspaceId, enabled, priorityOrder])
}

model WorkspaceSetting {
  id                                String       @id @default(cuid())
  workspaceId                       String       @unique
  timezone                          String       @default("UTC")
  defaultReviewQueue                ReviewQueue  @default(TRIAGE)
  classificationConfidenceThreshold Decimal      @default(0.7500) @db.Decimal(5, 4)
  taskConfidenceThreshold           Decimal      @default(0.7500) @db.Decimal(5, 4)
  autoCreateTasks                   Boolean      @default(true)
  autoApplyRoutingRules             Boolean      @default(true)
  archiveResolvedAfterDays          Int?
  businessThreshold                 Decimal      @default(0.8500) @db.Decimal(5, 4)
  personalThreshold                 Decimal      @default(0.2000) @db.Decimal(5, 4)
  weightContent                     Decimal      @default(0.4000) @db.Decimal(5, 4)
  weightSender                      Decimal      @default(0.2500) @db.Decimal(5, 4)
  weightSignature                   Decimal      @default(0.1500) @db.Decimal(5, 4)
  weightJob                         Decimal      @default(0.1500) @db.Decimal(5, 4)
  weightSubject                     Decimal      @default(0.0500) @db.Decimal(5, 4)
  createdAt                         DateTime     @default(now())
  updatedAt                         DateTime     @updatedAt
  workspace                         Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id         String    @id @default(cuid())
  workspaceId String
  actorUserId String?
  entityType String
  entityId   String
  action     String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser  User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType, entityId])
  @@index([actorUserId])
}

enum EntityType {
  CUSTOMER
  VENDOR
  JOB
}

enum AliasSource {
  MANUAL
  IMPORT
  REVIEW
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum DocumentType {
  CUSTOMER_LIST
  VENDOR_LIST
  JOB_LIST
  CLASSIFICATION_GUIDE
  OTHER
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model EntityAlias {
  id              String      @id @default(cuid())
  workspaceId     String
  entityType      EntityType
  customerId      String?
  vendorId        String?
  jobId           String?
  alias           String
  normalizedAlias String
  source          AliasSource @default(IMPORT)
  createdAt       DateTime    @default(now())
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer        Customer?   @relation(fields: [workspaceId, customerId], references: [workspaceId, id], onDelete: SetNull)
  vendor          Vendor?     @relation(fields: [workspaceId, vendorId], references: [workspaceId, id], onDelete: SetNull)
  job             Job?        @relation(fields: [workspaceId, jobId], references: [workspaceId, id], onDelete: SetNull)

  @@unique([workspaceId, entityType, normalizedAlias])
  @@index([workspaceId, normalizedAlias])
  @@index([customerId])
  @@index([vendorId])
  @@index([jobId])
}

model EntityContact {
  id              String    @id @default(cuid())
  workspaceId     String
  customerId      String?
  vendorId        String?
  name            String?
  email           String?
  normalizedEmail String?
  domain          String?
  phone           String?
  role            String?
  source          AliasSource @default(IMPORT)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [workspaceId, customerId], references: [workspaceId, id], onDelete: SetNull)
  vendor          Vendor?   @relation(fields: [workspaceId, vendorId], references: [workspaceId, id], onDelete: SetNull)

  @@index([workspaceId, normalizedEmail])
  @@index([workspaceId, domain])
  @@index([customerId])
  @@index([vendorId])
}

model KnowledgeDocument {
  id               String         @id @default(cuid())
  workspaceId      String
  filename         String
  mimeType         String
  status           DocumentStatus @default(UPLOADED)
  documentType     DocumentType   @default(OTHER)
  storageReference String?
  extractedText    String?
  extractedJson    Json?
  fileSize         Int?
  createdBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser    User?          @relation("DocumentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  importRuns       ImportRun[]

  @@index([workspaceId, documentType])
  @@index([workspaceId, status])
}

model ImportRun {
  id                   String             @id @default(cuid())
  workspaceId          String
  knowledgeDocumentId  String?
  importType           EntityType
  status               ImportStatus       @default(PENDING)
  rowsRead             Int                @default(0)
  createdCount         Int                @default(0)
  updatedCount         Int                @default(0)
  skippedCount         Int                @default(0)
  errorCount           Int                @default(0)
  errorsJson           Json?
  createdAt            DateTime           @default(now())
  completedAt          DateTime?
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeDocument    KnowledgeDocument? @relation(fields: [knowledgeDocumentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, importType])
  @@index([workspaceId, status])
}

model BusinessType {
  id            String    @id @default(cuid())
  workspaceId   String?
  systemKey     String
  displayLabel  String
  description   String?
  displayGroup  String?
  displayOrder  Int       @default(0)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, systemKey])
  @@index([systemKey])
  @@index([workspaceId, active])
  @@index([displayGroup, displayOrder])
}

model ClassificationCorrection {
  id                       String    @id @default(cuid())
  workspaceId              String
  classificationId         String
  originalMailboxCategory  String?
  correctedMailboxCategory String?
  originalBusinessType     String?
  correctedBusinessType    String?
  originalCustomerId       String?
  correctedCustomerId      String?
  originalVendorId         String?
  correctedVendorId        String?
  originalJobId            String?
  correctedJobId           String?
  originalPriority         String?
  correctedPriority        String?
  originalTaskData         Json?
  correctedTaskData        Json?
  reason                   String?
  reviewedByUserId         String?
  reviewedAt               DateTime  @default(now())
  createdAt                DateTime  @default(now())
  workspace                Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  classification           Classification @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  reviewedByUser           User?     @relation("CorrectionReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, classificationId])
  @@index([workspaceId, reviewedAt])
}

model ClassificationInstruction {
  id            String    @id @default(cuid())
  workspaceId   String
  title         String
  content       String
  active        Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser User?     @relation("InstructionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([workspaceId, active])
}

enum FolderStatus {
  DISCOVERED
  APPROVED
  IGNORED
}

model DiscoveredFolder {
  id                      String       @id @default(cuid())
  workspaceId             String
  provider                InboxProvider @default(OUTLOOK)
  mailboxEmail            String
  providerFolderId        String
  parentProviderFolderId  String?
  folderPath              String?
  rawFolderName           String
  normalizedFolderName    String
  detectedJobNumber       String?
  matchedJobId            String?
  status                  FolderStatus @default(DISCOVERED)
  childFolderCount        Int          @default(0)
  lastSeenAt              DateTime     @default(now())
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  workspace               Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  matchedJob              Job?         @relation(fields: [workspaceId, matchedJobId], references: [workspaceId, id], onDelete: SetNull)

  @@unique([workspaceId, providerFolderId])
  @@index([workspaceId, status])
  @@index([workspaceId, normalizedFolderName])
  @@index([matchedJobId])
}

model JobFolderRoot {
  id            String    @id @default(cuid())
  workspaceId   String
  rootName      String
  normalizedName String
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, active])
}

enum SenderStatus {
  OBSERVED
  LIKELY_BUSINESS
  CONFIRMED_BUSINESS
  CONFIRMED_PERSONAL
  BLOCKED
}

model SenderEvidence {
  id                          String       @id @default(cuid())
  workspaceId                 String
  senderEmail                 String
  normalizedEmail             String
  senderDomain                String
  displayName                 String?
  businessEvidenceCount       Int          @default(0)
  personalEvidenceCount       Int          @default(0)
  manualBusinessConfirmations Int          @default(0)
  manualPersonalConfirmations Int          @default(0)
  lastBusinessAt              DateTime?
  lastPersonalAt              DateTime?
  status                      SenderStatus @default(OBSERVED)
  confidence                  Decimal      @default(0) @db.Decimal(5, 4)
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  workspace                   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, normalizedEmail])
  @@index([workspaceId, senderDomain])
  @@index([workspaceId, status])
}

model DomainEvidence {
  id                          String       @id @default(cuid())
  workspaceId                 String
  domain                      String
  isPublicDomain              Boolean      @default(false)
  businessEvidenceCount       Int          @default(0)
  personalEvidenceCount       Int          @default(0)
  manualBusinessConfirmations Int          @default(0)
  manualPersonalConfirmations Int          @default(0)
  status                      SenderStatus @default(OBSERVED)
  confidence                  Decimal      @default(0) @db.Decimal(5, 4)
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  workspace                   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, domain])
  @@index([workspaceId, status])
}

enum AttachmentUploadStatus {
  PENDING
  UPLOADED
  FAILED
}

model EmailAttachment {
  id                    String                @id @default(cuid())
  workspaceId           String
  emailMessageId        String
  providerAttachmentId  String?
  filename              String
  sanitizedFilename     String
  mimeType              String
  sizeBytes             Int
  storageKey            String?
  checksum              String?
  isInline              Boolean               @default(false)
  uploadStatus          AttachmentUploadStatus @default(PENDING)
  errorMessage          String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emailMessage          EmailMessage          @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@unique([emailMessageId, providerAttachmentId])
  @@unique([workspaceId, storageKey])
  @@index([workspaceId, emailMessageId])
  @@index([checksum])
}
